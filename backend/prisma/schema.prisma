datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  username   String?
  firstName  String?
  lastName   String?
  photoUrl   String?
  webToken   String?  @unique // ← токен для входа на фронт
  createdAt  DateTime @default(now())

  couplesAsGirl Couple[] @relation("Girl")
  couplesAsBoy  Couple[] @relation("Boy")
}

model Couple {
  id        Int      @id @default(autoincrement())
  girlId    Int
  boyId     Int
  createdAt DateTime @default(now())

  girl User @relation("Girl", fields: [girlId], references: [id], onDelete: Cascade)
  boy  User @relation("Boy", fields: [boyId], references: [id], onDelete: Cascade)

  cycles Cycle[]
}

model Cycle {
  id          Int      @id @default(autoincrement())
  startDate   DateTime
  cycleLength Int
  coupleId    Int

  couple Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  wishes Wish[]
}

model Wish {
  id      Int    @id @default(autoincrement())
  text    String
  cycleId Int

  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
}

model TelegramLogin {
  id         String   @id @default(uuid())
  token      String   @unique
  telegramId String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  used       Boolean  @default(false)

  @@index([token])
}
