datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  username   String?
  firstName  String?
  lastName   String?
  photoUrl   String?
  balance    Int      @default(0)
  createdAt  DateTime @default(now())

  couplesAsCreator Couple[] @relation("Creator")
  couplesAsPartner Couple[] @relation("Partner")
}

model Couple {
  id              Int       @id @default(autoincrement())
  creatorId       Int
  partnerId       Int?      // null пока партнёр не принял приглашение
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?
  createdAt       DateTime  @default(now())

  creator User  @relation("Creator", fields: [creatorId], references: [id], onDelete: Cascade)
  partner User? @relation("Partner", fields: [partnerId], references: [id], onDelete: SetNull)

  wishes Wish[]
  cycles Cycle[]
}

model Wish {
  id        Int      @id @default(autoincrement())
  text      String
  cost      Int      @default(0)
  order     Int      @default(0)  // для drag & drop
  done      Boolean  @default(false)
  coupleId  Int
  createdAt DateTime @default(now())

  couple Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model Cycle {
  id          Int      @id @default(autoincrement())
  startDate   DateTime
  cycleLength Int
  coupleId    Int
  isActive    Boolean  @default(true)  // ← добавить
  createdAt   DateTime @default(now())

  couple  Couple           @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  entries CycleWishEntry[]
}

// Снапшот хотелок на момент создания цикла + статус выполнения
model CycleWishEntry {
  id       Int     @id @default(autoincrement())
  cycleId  Int
  wishText String
  cost     Int
  done     Boolean @default(false)

  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
}

model TelegramLogin {
  id         String   @id @default(uuid())
  token      String   @unique
  telegramId String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  used       Boolean  @default(false)

  @@index([token])
}
